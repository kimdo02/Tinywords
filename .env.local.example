# Supabase 프로젝트 설정값 (Supabase 대시보드 > Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# 서버 전용 키 (선택, 관리 작업용 - 클라이언트에 노출 금지)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI 이미지 생성 (단어 등록 시 AI 그림). 서버 전용 - 클라이언트 노출 금지.
# 없으면 AI 그림 버튼이 비활성화될 뿐, 앱은 정상 동작합니다.
OPENAI_API_KEY=sk-...
